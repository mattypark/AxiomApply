---
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" type="image/png" href="/axiom-mark.png" />
  <title>Axiom Pathways — Connecting young talent to their passions</title>
  <meta name="description" content="Axiom Pathways is a nonprofit teaching high school and college students the foundations of modern startups — AI, computer science, and marketing." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300..700;1,9..40,400..600&display=swap" rel="stylesheet" />
</head>
<body>

  <!-- HOME -->
  <section class="panel hero-panel" id="top">
    <div class="hero-canvas">
      <div class="h-mark" aria-hidden="true"></div>

      <div class="h-tl">
        <span class="h-est">Est. May 2025 — very new</span>
      </div>

      <img class="h-logo-mobile" src="/axiom-mark.png" alt="Axiom Pathways" />

      <div class="h-center">
        <h1><span class="l1">Axiom</span><span class="l2">Pathways</span></h1>
      </div>

      <div class="h-metrics">
        <div class="metric"><span class="ml">Startups</span><span class="mv">6 partners</span></div>
        <div class="metric"><span class="ml">Interns</span><span class="mv">0 placed</span></div>
        <div class="metric"><span class="ml">Team</span><span class="mv">2 founders</span></div>
        <div class="metric"><span class="ml">Outreach</span><span class="mv">SF & NYC</span></div>
      </div>

      <div class="h-desc">
        <p>We drop high school and college students straight into real startups — building what ships, not slide decks. Picked for passion, not credentials.</p>
        <a class="know" href="#apply">Start your application →</a>
      </div>
    </div>
  </section>

  <!-- APPLICATION -->
  <section class="apply-section" id="apply">
    <div class="apply-inner">
      <div id="formWrap">
      <span class="tag reveal"><span class="plus">+</span> The application</span>
      <h2 class="sec-title reveal">One step <em>at a time.</em></h2>
      <div class="sec-rule"></div>
        <form id="applyForm" class="reveal" novalidate>
          <div class="stepper">
            <div class="stepper-dots">
              <span class="sdot active" data-dot="0"></span>
              <span class="sdot" data-dot="1"></span>
              <span class="sdot" data-dot="2"></span>
            </div>
            <div class="stepper-label"><span id="stepNum">1</span> / 3 — <span id="stepName">About you</span></div>
          </div>

          <!-- Step 1 -->
          <div class="step-panel active" data-step="0">
            <fieldset class="fieldset">
              <p class="hint">The basics so we can reach you. All required.</p>
              <div class="grid-2">
                <div class="field">
                  <label for="name">Full name <span class="star">*</span></label>
                  <input id="name" name="name" type="text" required autocomplete="name" />
                </div>
                <div class="field">
                  <label for="email">Email <span class="star">*</span></label>
                  <input id="email" name="email" type="email" required autocomplete="email" />
                </div>
                <div class="field">
                  <label for="phone">Phone <span class="star">*</span></label>
                  <input id="phone" name="phone" type="tel" required autocomplete="tel" />
                </div>
                <div class="field">
                  <label for="school">School <span class="star">*</span></label>
                  <input id="school" name="school" type="text" required />
                </div>
                <div class="field">
                  <label for="grade">Grade / Year <span class="star">*</span></label>
                  <select id="grade" name="grade" required>
                    <option value="" disabled selected>Select…</option>
                    <option>9th grade</option>
                    <option>10th grade</option>
                    <option>11th grade</option>
                    <option>12th grade</option>
                    <option>College — Freshman</option>
                    <option>College — Sophomore</option>
                    <option>College — Junior</option>
                    <option>College — Senior</option>
                    <option>Other</option>
                  </select>
                </div>
              </div>
            </fieldset>
          </div>

          <!-- Step 2 -->
          <div class="step-panel" data-step="1">
            <fieldset class="fieldset">
              <p class="hint">Where you want to fit and what you want to learn. All required.</p>
              <div class="grid-2">
                <div class="field">
                  <label for="interest">Main interest <span class="star">*</span></label>
                  <select id="interest" name="interest" required>
                    <option value="" disabled selected>Select…</option>
                    <option>AI</option>
                    <option>Computer Science</option>
                    <option>Marketing</option>
                    <option>Finance</option>
                    <option>Startups</option>
                    <option>Other</option>
                  </select>
                </div>
                <div class="field" id="interestOtherField" style="display:none">
                  <label for="interestOther">Tell us what <span class="star">*</span></label>
                  <input id="interestOther" name="interest_other" type="text" placeholder="What else are you interested in?" />
                </div>
                <div class="field">
                  <label for="chapter">City / Chapter <span class="star">*</span></label>
                  <input id="chapter" name="chapter" type="text" required placeholder="e.g. Bay Area, Online" />
                </div>
              </div>
              <div class="field">
                <label for="startup_role">What startup internship are you looking for? <span class="star">*</span> <span class="optnote">(maximum 100 words)</span></label>
                <textarea id="startup_role" name="startup_role" required placeholder="e.g. AI engineer at an early-stage startup, marketing intern at a consumer app…"></textarea>
              </div>
              <div class="field">
                <label for="background">Why that, and what's your background? <span class="star">*</span> <span class="optnote">(maximum 200 words)</span></label>
                <textarea id="background" name="background" required placeholder="What draws you to that role and what have you done so far?"></textarea>
              </div>
              <div class="field">
                <label for="fields_interest">What fields are you interested in? <span class="star">*</span></label>
                <textarea id="fields_interest" name="fields_interest" required placeholder="e.g. AI infra, consumer growth, fintech, devtools…"></textarea>
              </div>
              <div class="field">
                <label for="startup_picks">What startups do you want to join specifically? <span class="star">*</span></label>
                <textarea id="startup_picks" name="startup_picks" required placeholder="Our partners: FinalDose, Stealth YC S26, Anvara, Tally, Quarter Life Crisis, Topit AI, TypeOS YC X25"></textarea>
              </div>
            </fieldset>
          </div>

          <!-- Step 3 -->
          <div class="step-panel" data-step="2">
            <fieldset class="fieldset">
              <p class="hint">Optional. No résumé — just tell us what you want to build, why it matters, and drop your socials.</p>
              <div class="field">
                <label for="letter">What do you want to build, and why does it matter to you? <span class="optnote">(maximum 100 words)</span></label>
                <textarea id="letter" name="letter" placeholder="A few paragraphs is plenty."></textarea>
              </div>
              <div class="grid-2">
                <div class="field">
                  <label for="instagram">Instagram <span class="star">*</span></label>
                  <input id="instagram" name="instagram" type="text" required placeholder="@handle" />
                </div>
                <div class="field">
                  <label for="linkedin">LinkedIn <span class="star">*</span></label>
                  <input id="linkedin" name="linkedin" type="text" required placeholder="profile URL" />
                </div>
                <div class="field">
                  <label for="github">GitHub <span class="optnote">(highly recommended)</span></label>
                  <input id="github" name="github" type="text" placeholder="@username" />
                </div>
                <div class="field">
                  <label for="other_link">Other link</label>
                  <input id="other_link" name="other_link" type="text" placeholder="portfolio, X, TikTok…" />
                </div>
              </div>
              <div class="field">
                <label for="resume">Resume / CV <span class="optnote">(optional — PDF, DOC, max 8MB)</span></label>
                <input id="resume" name="resume" type="file" accept=".pdf,.doc,.docx,application/pdf" />
              </div>
              <div class="field">
                <label for="comments">Anything else you want to share with us?</label>
                <textarea id="comments" name="comments" placeholder="Anything goes — context, questions, fun facts…"></textarea>
              </div>
              <div class="field">
                <label for="extra_file">Additional file <span class="optnote">(optional — image, PDF, etc. max 8MB)</span></label>
                <input id="extra_file" name="extra_file" type="file" accept=".pdf,.doc,.docx,.png,.jpg,.jpeg,.gif,image/*,application/pdf" />
              </div>
            </fieldset>
          </div>

          <div class="form-actions">
            <button class="btn btn-ghost" type="button" id="backBtn" style="display:none">← Back</button>
            <button class="btn btn-primary" type="button" id="nextBtn">Next <span class="arrow">→</span></button>
            <button class="btn btn-primary" type="button" id="submitBtn" style="display:none">Submit application <span class="arrow">→</span></button>
          </div>
        </form>
      </div>

      <!-- Success screen (replaces form after submit) -->
      <div id="successScreen" class="success-screen" style="display:none">
        <div class="success-checkmark">
          <svg class="checkmark-svg" viewBox="0 0 52 52">
            <circle class="checkmark-circle" cx="26" cy="26" r="25" fill="none" />
            <path class="checkmark-check" fill="none" d="M14.1 27.2l7.1 7.2 16.7-16.8" />
          </svg>
        </div>
        <h3 class="success-title">Received. We'll get back to you soon.</h3>
        <p class="success-sub">Check your email for results soon.</p>
      </div>
    </div>
  </section>

  <!-- PARTNERS -->
  <section class="partners-section" id="partners">
    <div class="partners-inner">
      <div class="partners-head">
        <span class="tag reveal"><span class="plus">+</span> The partners</span>
        <h2 class="sec-title reveal">Where you'll <em>actually work.</em></h2>
        <p class="partners-lede reveal">Seven startups. Real codebases, real customers, real stakes. Pick one, tell us why, and we'll make the intro.</p>
      </div>

      <div class="p-ledger reveal">

        <article class="p-row">
          <div class="p-row-top">
            <span class="p-num">01</span>
            <h3 class="p-name">FinalDose <span class="p-yc-text">YC&nbsp;P26</span></h3>
            <span class="p-sector">Biotech / Medicine</span>
            <span class="p-status">Cohort opens summer</span>
            <span class="p-arrow" aria-hidden="true">↗</span>
          </div>
          <div class="p-row-detail">
            <div class="p-detail-grid">
              <div class="p-detail-col">
                <span class="p-detail-label">What they do</span>
                <p>Building the world's first programmable drug — engineered to target and cure all cancers. Deep science, massive ambition, ground floor.</p>
              </div>
              <div class="p-detail-col">
                <span class="p-detail-label">The role</span>
                <ul class="p-chips">
                  <li>Medicine</li>
                  <li>Research</li>
                  <li>Software engineering</li>
                </ul>
              </div>
              <div class="p-detail-col">
                <span class="p-detail-label">The details</span>
                <p>Not taking interns yet — first cohort opens this summer (June–August), built for students serious about medicine. Technical applicants like software engineers are welcome too.</p>
              </div>
            </div>
          </div>
        </article>

        <article class="p-row">
          <div class="p-row-top">
            <span class="p-num">02</span>
            <h3 class="p-name">Stealth <span class="p-yc-text">YC&nbsp;S26</span></h3>
            <span class="p-sector">Hardware</span>
            <span class="p-status">Taking interns</span>
            <span class="p-arrow" aria-hidden="true">↗</span>
          </div>
          <div class="p-row-detail">
            <div class="p-detail-grid">
              <div class="p-detail-col">
                <span class="p-detail-label">What they do</span>
                <p>Still in stealth — backed by Y Combinator (S26). The full picture is under wraps for now, but it's serious hardware with a team that's already shipping.</p>
              </div>
              <div class="p-detail-col">
                <span class="p-detail-label">The role</span>
                <ul class="p-chips">
                  <li>Hardware</li>
                  <li>Prototyping</li>
                  <li>Engineering</li>
                </ul>
              </div>
              <div class="p-detail-col">
                <span class="p-detail-label">The details</span>
                <p>Looking for hardware interns who are genuinely obsessed with building physical things. If you tinker, prototype, and can't stop making — this is your room.</p>
              </div>
            </div>
          </div>
        </article>

        <article class="p-row">
          <div class="p-row-top">
            <span class="p-num">03</span>
            <h3 class="p-name">Anvara</h3>
            <span class="p-sector">Sponsorships / Marketplace</span>
            <span class="p-status">Taking interns</span>
            <span class="p-arrow" aria-hidden="true">↗</span>
          </div>
          <div class="p-row-detail">
            <div class="p-detail-grid">
              <div class="p-detail-col">
                <span class="p-detail-label">What they do</span>
                <p>Anvara is the marketplace for sponsorships — connecting brands with sports teams, festivals, and live events worldwide. One platform for the entire deal: discovery, contracts, payments, and performance tracking.</p>
              </div>
              <div class="p-detail-col">
                <span class="p-detail-label">The role</span>
                <ul class="p-chips">
                  <li>Partnerships &amp; growth</li>
                  <li>Brand outreach</li>
                  <li>Market research</li>
                  <li>Deal sourcing</li>
                </ul>
              </div>
              <div class="p-detail-col">
                <span class="p-detail-label">The details</span>
                <p>Source and onboard brands and rightsholders onto the platform — real business development with a fast-moving NYC team. Remote friendly; in-person in New York strongly preferred.</p>
              </div>
            </div>
          </div>
        </article>

        <article class="p-row">
          <div class="p-row-top">
            <span class="p-num">04</span>
            <h3 class="p-name">Tally</h3>
            <span class="p-sector">Consumer / Social</span>
            <span class="p-status">Taking interns</span>
            <span class="p-arrow" aria-hidden="true">↗</span>
          </div>
          <div class="p-row-detail">
            <div class="p-detail-grid">
              <div class="p-detail-col">
                <span class="p-detail-label">What they do</span>
                <p>Bet on yourself — literally. Put money on your own goals: work out, cook, ship the thing. Do it, keep the money and win from the group. Skip it, the group takes yours. Accountability with real stakes, launching June 13.</p>
              </div>
              <div class="p-detail-col">
                <span class="p-detail-label">The role</span>
                <ul class="p-chips">
                  <li>Execution</li>
                  <li>Video editing</li>
                  <li>Content creation</li>
                  <li>Launch support</li>
                </ul>
              </div>
              <div class="p-detail-col">
                <span class="p-detail-label">The details</span>
                <p>Work directly with the founders during launch — editing, content, and whatever needs to ship that day. Pure execution role on a brand-new consumer app at day zero.</p>
              </div>
            </div>
          </div>
        </article>

        <article class="p-row">
          <div class="p-row-top">
            <span class="p-num">05</span>
            <h3 class="p-name">Quarter Life Crisis</h3>
            <span class="p-sector">Brand / Lifestyle</span>
            <span class="p-status">Taking interns</span>
            <span class="p-arrow" aria-hidden="true">↗</span>
          </div>
          <div class="p-row-detail">
            <div class="p-detail-grid">
              <div class="p-detail-col">
                <span class="p-detail-label">What they do</span>
                <p>A brand built around the chaos of figuring your life out — and the merch to match. Early-stage, culture-first, and growing through community and drops.</p>
              </div>
              <div class="p-detail-col">
                <span class="p-detail-label">The role</span>
                <ul class="p-chips">
                  <li>Marketing</li>
                  <li>Merch design</li>
                  <li>Campaigns</li>
                  <li>Brand growth</li>
                </ul>
              </div>
              <div class="p-detail-col">
                <span class="p-detail-label">The details</span>
                <p>Own marketing and merch from day one. Prove yourself here and they'll bring you deeper into the startup — this is a real foot in the door.</p>
              </div>
            </div>
          </div>
        </article>

        <article class="p-row">
          <div class="p-row-top">
            <span class="p-num">06</span>
            <h3 class="p-name">Topit AI</h3>
            <span class="p-sector">AI / Consumer</span>
            <span class="p-status">Taking interns</span>
            <span class="p-arrow" aria-hidden="true">↗</span>
          </div>
          <div class="p-row-detail">
            <div class="p-detail-grid">
              <div class="p-detail-col">
                <span class="p-detail-label">What they do</span>
                <p>An AI startup building consumer-facing products with a culture-first, internet-native brand. Fast-moving and growing through content.</p>
              </div>
              <div class="p-detail-col">
                <span class="p-detail-label">The role</span>
                <ul class="p-chips">
                  <li>Marketing</li>
                  <li>Social &amp; content</li>
                  <li>Software engineering</li>
                </ul>
              </div>
              <div class="p-detail-col">
                <span class="p-detail-label">The details</span>
                <p>Mostly marketing and content — own the brand's voice and growth. Technical applicants like software engineers welcome too.</p>
              </div>
            </div>
          </div>
        </article>

        <article class="p-row">
          <div class="p-row-top">
            <span class="p-num">07</span>
            <h3 class="p-name">TypeOS <span class="p-yc-text">YC&nbsp;X25</span></h3>
            <span class="p-sector">AI / Productivity</span>
            <span class="p-status">Taking interns</span>
            <span class="p-arrow" aria-hidden="true">↗</span>
          </div>
          <div class="p-row-detail">
            <div class="p-detail-grid">
              <div class="p-detail-col">
                <span class="p-detail-label">What they do</span>
                <p>TypeOS is the AI layer for writing. Starting with Google Docs, you can write, edit, and format your documents with AI — reference any article, video, or file across the web without ever switching tabs.</p>
              </div>
              <div class="p-detail-col">
                <span class="p-detail-label">The role</span>
                <ul class="p-chips">
                  <li>Marketing</li>
                  <li>Research</li>
                  <li>Content &amp; growth</li>
                </ul>
              </div>
              <div class="p-detail-col">
                <span class="p-detail-label">The details</span>
                <p>Mainly marketing and research. If you're a high schooler who's genuinely ambitious, they'll take anyone driven for their fellowship — show up hungry and prove it.</p>
              </div>
            </div>
          </div>
        </article>

      </div>

      <div class="partners-foot reveal">
        <span class="pf-note">More partners joining — apply early, get first pick.</span>
        <a class="btn btn-primary" href="#apply">Apply now <span class="arrow">→</span></a>
      </div>
    </div>
  </section>

<script>
  import { inject } from "@vercel/analytics";
  inject();

  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  import Lenis from "lenis";

  gsap.registerPlugin(ScrollTrigger);

  const lenis = new Lenis({ duration: 1.1, smoothWheel: true });
  function raf(time: number) { lenis.raf(time); requestAnimationFrame(raf); }
  requestAnimationFrame(raf);
  lenis.on("scroll", ScrollTrigger.update);

  document.querySelectorAll('a[href^="#"]').forEach((a) => {
    a.addEventListener("click", (e) => {
      const id = (a as HTMLAnchorElement).getAttribute("href")!;
      if (id.length > 1) { e.preventDefault(); lenis.scrollTo(id, { offset: -20 }); }
    });
  });

  gsap.set([".h-mark", ".h-metrics", ".h-desc"], { opacity: 0, y: 20 });
  gsap.set(".h-center", { opacity: 0 });
  gsap.to([".h-metrics", ".h-desc"], {
    opacity: 1, y: 0, duration: 0.9, ease: "power3.out", stagger: 0.1,
  });
  gsap.to(".h-center", { opacity: 1, duration: 0.9, ease: "power3.out" });
  gsap.to(".h-mark", { opacity: 1, y: 0, duration: 1.1, ease: "power3.out" });

  gsap.utils.toArray<HTMLElement>(".reveal").forEach((el) => {
    gsap.to(el, {
      opacity: 1, y: 0, duration: 0.8, ease: "power3.out",
      scrollTrigger: { trigger: el, start: "top 88%" },
    });
  });

  // Partners ledger — tap to expand on touch devices
  document.querySelectorAll<HTMLElement>(".p-row").forEach((row) => {
    row.addEventListener("click", () => {
      const wasOpen = row.classList.contains("open");
      document.querySelectorAll(".p-row.open").forEach((r) => r.classList.remove("open"));
      if (!wasOpen) row.classList.add("open");
    });
  });

  // ---- Multi-step wizard ----
  const STEP_NAMES = ["About you", "Your focus", "The letter"];
  const stepPanels = Array.from(document.querySelectorAll<HTMLElement>(".step-panel"));
  const dots = Array.from(document.querySelectorAll<HTMLElement>(".sdot"));
  const backBtn = document.getElementById("backBtn") as HTMLButtonElement;
  const nextBtn = document.getElementById("nextBtn") as HTMLButtonElement;
  const submitBtn = document.getElementById("submitBtn") as HTMLButtonElement;
  const stepNum = document.getElementById("stepNum")!;
  const stepName = document.getElementById("stepName")!;
  const form = document.getElementById("applyForm") as HTMLFormElement;
  let current = 0;

  function showStep(i: number) {
    stepPanels.forEach((p, idx) => p.classList.toggle("active", idx === i));
    dots.forEach((d, idx) => d.classList.toggle("active", idx <= i));
    stepNum.textContent = String(i + 1);
    stepName.textContent = STEP_NAMES[i];
    backBtn.style.display = i === 0 ? "none" : "";
    nextBtn.style.display = i === stepPanels.length - 1 ? "none" : "";
    submitBtn.style.display = i === stepPanels.length - 1 ? "" : "none";
    gsap.fromTo(stepPanels[i], { opacity: 0, y: 16 }, { opacity: 1, y: 0, duration: 0.4, ease: "power2.out" });
  }

  function validateStep(i: number): boolean {
    const fields = stepPanels[i].querySelectorAll<HTMLInputElement | HTMLSelectElement>("input, select, textarea");
    for (const f of fields) {
      if (!f.checkValidity()) { f.reportValidity(); return false; }
    }
    return true;
  }

  // Show "tell us what" only when Main interest = Other
  const interestSel = document.getElementById("interest") as HTMLSelectElement;
  const interestOtherField = document.getElementById("interestOtherField") as HTMLElement;
  const interestOther = document.getElementById("interestOther") as HTMLInputElement;
  interestSel.addEventListener("change", () => {
    const isOther = interestSel.value === "Other";
    interestOtherField.style.display = isOther ? "" : "none";
    interestOther.required = isOther;
    if (!isOther) interestOther.value = "";
  });

  nextBtn.addEventListener("click", () => {
    if (!validateStep(current)) return;
    if (current < stepPanels.length - 1) { current++; showStep(current); }
  });
  backBtn.addEventListener("click", () => {
    if (current > 0) { current--; showStep(current); }
  });

  // ---- Submit → Apps Script webhook ----
  const WEBHOOK_URL = "https://script.google.com/macros/s/AKfycbwxvxSnqkHtXmDmZivo-AW4BllLdT5mWQrQYoV2v1J47hojuEvpf5GPzIGlppkO1K0c/exec";
  const formWrap = document.getElementById("formWrap") as HTMLElement;
  const successScreen = document.getElementById("successScreen") as HTMLElement;

  function fileToBase64(file: File): Promise<string> {
    return new Promise((resolve, reject) => {
      const reader = new FileReader();
      reader.onload = () => resolve((reader.result as string).split(",")[1] || "");
      reader.onerror = reject;
      reader.readAsDataURL(file);
    });
  }

  // Block all native form submissions — submit only via button click
  form.addEventListener("submit", (e) => { e.preventDefault(); });

  submitBtn.addEventListener("click", async () => {
    if (current !== stepPanels.length - 1) return;
    if (!validateStep(current)) return;

    submitBtn.disabled = true;
    submitBtn.textContent = "Sending…";

    // Collect text fields
    const fd = new FormData(form);
    const data: Record<string, string> = {};
    fd.forEach((v, k) => { if (typeof v === "string") data[k] = v; });
    if (data.interest === "Other" && data.interest_other) {
      data.interest = "Other — " + data.interest_other;
    }
    delete data.interest_other;

    // Resume file → base64
    const resumeInput = document.getElementById("resume") as HTMLInputElement;
    const resumeFile = resumeInput.files && resumeInput.files[0];
    if (resumeFile) {
      if (resumeFile.size > 8 * 1024 * 1024) {
        submitBtn.textContent = "Resume too large (max 8MB).";
        submitBtn.disabled = false;
        return;
      }
      data.resume_name = resumeFile.name;
      data.resume_type = resumeFile.type || "application/octet-stream";
      data.resume_base64 = await fileToBase64(resumeFile);
    }

    // Extra file → base64
    const extraInput = document.getElementById("extra_file") as HTMLInputElement;
    const extraFile = extraInput.files && extraInput.files[0];
    if (extraFile) {
      if (extraFile.size > 8 * 1024 * 1024) {
        submitBtn.textContent = "Extra file too large (max 8MB).";
        submitBtn.disabled = false;
        return;
      }
      data.extra_file_name = extraFile.name;
      data.extra_file_type = extraFile.type || "application/octet-stream";
      data.extra_file_base64 = await fileToBase64(extraFile);
    }

    // Send as URL-encoded (not FormData) — Apps Script e.parameter needs this
    const submitData = new URLSearchParams(data);

    try {
      await fetch(WEBHOOK_URL, {
        method: "POST",
        mode: "no-cors",
        body: submitData,
      });
    } catch (_) {}

    // Wait a moment for Apps Script to process
    await new Promise((r) => setTimeout(r, 1500));

    // Hide form, show success screen
    formWrap.style.display = "none";
    successScreen.style.display = "";
    gsap.fromTo(successScreen, { opacity: 0, y: 20 }, { opacity: 1, y: 0, duration: 0.6, ease: "power3.out" });
  });
</script>

</body>
</html>
