---
import "../styles/global.css";

// Full startup data — drives the trusted row, the inline Apply list, and the
// expandable full startups list. yc = null when the company isn't YC-backed.
const startups = [
  {
    name: "FinalDose", yc: "YC P26", sector: "Biotech / Medicine", status: "Cohort opens summer",
    what: "Building the world's first programmable drug — engineered to target and cure all cancers. Deep science, massive ambition, ground floor.",
    roles: ["Medicine", "Research", "Software engineering"],
    details: "Not taking interns yet — first cohort opens this summer (June–August), built for students serious about medicine. Technical applicants like software engineers are welcome too.",
  },
  {
    name: "Stealth", yc: "YC S26", sector: "Hardware", status: "Taking interns",
    what: "Still in stealth — backed by Y Combinator (S26). The full picture is under wraps for now, but it's serious hardware with a team that's already shipping.",
    roles: ["Hardware", "Prototyping", "Engineering"],
    details: "Looking for hardware interns who are genuinely obsessed with building physical things. If you tinker, prototype, and can't stop making — this is your room.",
  },
  {
    name: "Anvara", yc: null, sector: "Sponsorships / Marketplace", status: "Taking interns",
    what: "The marketplace for sponsorships — connecting brands with sports teams, festivals, and live events worldwide. One platform for the entire deal: discovery, contracts, payments, and performance tracking.",
    roles: ["Partnerships & growth", "Brand outreach", "Market research", "Deal sourcing"],
    details: "Source and onboard brands and rightsholders onto the platform — real business development with a fast-moving NYC team. Remote friendly; in-person in New York strongly preferred.",
  },
  {
    name: "Tally", yc: null, sector: "Consumer / Social", status: "Taking interns",
    what: "Bet on yourself — literally. Put money on your own goals: work out, cook, ship the thing. Do it, keep the money and win from the group. Skip it, the group takes yours. Accountability with real stakes.",
    roles: ["Execution", "Video editing", "Content creation", "Launch support"],
    details: "Work directly with the founders during launch — editing, content, and whatever needs to ship that day. Pure execution role on a brand-new consumer app at day zero.",
  },
  {
    name: "Quarter Life Crisis", yc: null, sector: "Brand / Lifestyle", status: "Taking interns",
    what: "A brand built around the chaos of figuring your life out — and the merch to match. Early-stage, culture-first, and growing through community and drops.",
    roles: ["Marketing", "Merch design", "Campaigns", "Brand growth"],
    details: "Own marketing and merch from day one. Prove yourself here and they'll bring you deeper into the startup — this is a real foot in the door.",
  },
  {
    name: "Topit AI", yc: null, sector: "AI / Consumer", status: "Taking interns",
    what: "An AI startup building consumer-facing products with a culture-first, internet-native brand. Fast-moving and growing through content.",
    roles: ["Marketing", "Social & content", "Software engineering"],
    details: "Mostly marketing and content — own the brand's voice and growth. Technical applicants like software engineers welcome too.",
  },
  {
    name: "TypeOS", yc: "YC X25", sector: "AI / Productivity", status: "Taking interns",
    what: "The AI layer for writing. Starting with Google Docs, you can write, edit, and format your documents with AI — reference any article, video, or file across the web without ever switching tabs.",
    roles: ["Marketing", "Research", "Content & growth"],
    details: "Mainly marketing and research. If you're a high schooler who's genuinely ambitious, they'll take anyone driven for their fellowship — show up hungry and prove it.",
  },
];
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" type="image/png" href="/axiom-mark.png" />
  <title>Axiom Pathways — Drop into a real startup</title>
  <meta name="description" content="Axiom Pathways drops high school and college students straight into real startups — building what ships, picked for passion, not credentials." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,300..600;1,6..72,300..500&display=swap" rel="stylesheet" />
</head>
<body>

  <!-- BACKGROUND SHAPE FIELD -->
  <canvas class="bg-dots" id="bgDots" aria-hidden="true"></canvas>

  <!-- No top nav — everything lives in the chat (type ? to see options) -->

  <!-- HERO -->
  <main class="hero">
    <img class="hero-logo" src="/axiom-logo.png" alt="Axiom Pathways" />
    <p class="hero-tagline">Drop into a real startup. Build what ships — picked for passion, not credentials.</p>

    <div class="ai" id="aiBox">
      <div class="ai-thread" id="aiThread" aria-live="polite"></div>
      <p class="ai-hint" id="aiHint">Type <strong>Apply</strong> to start your application — or <strong>?</strong> to see everything you can do.</p>
      <form class="ai-input" id="aiForm" autocomplete="off">
        <span class="ai-plus" aria-hidden="true">+</span>
        <input id="aiField" type="text" placeholder="Ask how Axiom works, or type Apply…" aria-label="Message Axiom" />
        <button type="submit" class="ai-send" aria-label="Send">↑</button>
      </form>
    </div>

    <section class="trusted">
      <p class="trusted-label">Trusted by fast-growing startups worldwide</p>
      <div class="trusted-marquee">
        <ul class="trusted-track">
          {startups.map((s) => (
            <li class="trusted-logo" title={s.name}>{s.name}{s.yc && <span class="trusted-yc"> {s.yc}</span>}</li>
          ))}
          {startups.map((s) => (
            <li class="trusted-logo" aria-hidden="true">{s.name}{s.yc && <span class="trusted-yc"> {s.yc}</span>}</li>
          ))}
        </ul>
      </div>
    </section>
  </main>

  <!-- HOW CAN I USE AXIOM PATHWAYS -->
  <section class="howuse">
    <h2 class="howuse-title">We connect young talent to their&nbsp;passions.</h2>
    <p class="howuse-sub">High school and college students, dropped into real startups — building what ships, learning directly from top entrepreneurs.</p>
  </section>

  <!-- FOOTER -->
  <footer class="site-footer">
    <div class="footer-left">
      <a href="/contact">Contact</a>
      <a href="https://www.linkedin.com/company/axiom-pathways" target="_blank" rel="noopener">LinkedIn</a>
      <span>Axiom Pathways</span>
    </div>
    <div class="footer-right">
      <a class="footer-social" href="/social">Social media ↗</a>
    </div>
  </footer>

  <!-- FULL STARTUPS LIST — expandable rows (hover / click).
       data-lenis-prevent lets this overlay scroll natively (Lenis owns the page wheel). -->
  <section class="flow flow-startups" id="startupsFlow" aria-hidden="true" data-lenis-prevent>
    <button type="button" class="flow-x" id="startupsX" aria-label="Close">&times;</button>
    <div class="flow-head">
      <span class="flow-eyebrow">Where you could land</span>
      <h2 class="flow-title">The startups.</h2>
    </div>

    <div class="p-ledger">
      {startups.map((s, i) => (
        <article class="p-row">
          <div class="p-row-top">
            <span class="p-num">{(i + 1).toString().padStart(2, "0")}</span>
            <h3 class="p-name">{s.name}{s.yc && <span class="p-yc-text"> {s.yc}</span>}</h3>
            <span class="p-sector">{s.sector}</span>
            <span class="p-status">{s.status}</span>
            <span class="p-arrow" aria-hidden="true">↗</span>
          </div>
          <div class="p-row-detail">
            <div class="p-detail-grid">
              <div class="p-detail-col">
                <span class="p-detail-label">What they do</span>
                <p>{s.what}</p>
              </div>
              <div class="p-detail-col">
                <span class="p-detail-label">The role</span>
                <ul class="p-chips">{s.roles.map((r) => <li>{r}</li>)}</ul>
              </div>
              <div class="p-detail-col">
                <span class="p-detail-label">The details</span>
                <p>{s.details}</p>
              </div>
            </div>
          </div>
        </article>
      ))}
    </div>

    <div class="flow-foot">
      <button type="button" class="flow-back" data-close-flow="startupsFlow">← Back</button>
    </div>
  </section>

<script>
  import { inject } from "@vercel/analytics";
  inject();
  import { gsap } from "gsap";
  import Lenis from "lenis";

  const startups = [
    { name: "FinalDose", yc: "YC P26", meta: "Biotech / Medicine · cohort opens summer" },
    { name: "Stealth", yc: "YC S26", meta: "Hardware · taking interns" },
    { name: "Anvara", yc: null, meta: "Sponsorships / Marketplace · taking interns" },
    { name: "Tally", yc: null, meta: "Consumer / Social · taking interns" },
    { name: "Quarter Life Crisis", yc: null, meta: "Brand / Lifestyle · taking interns" },
    { name: "Topit AI", yc: null, meta: "AI / Consumer · taking interns" },
    { name: "TypeOS", yc: "YC X25", meta: "AI / Productivity · taking interns" },
  ];

  const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  const D = (n) => (reduce ? Math.min(n, 0.1) : n);

  // ---- Sexy scroll ----
  let lenis = null;
  if (!reduce) {
    lenis = new Lenis({ duration: 1.2, easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)), smoothWheel: true });
    const raf = (time) => { lenis.raf(time); requestAnimationFrame(raf); };
    requestAnimationFrame(raf);
  }

  // ---- Intro ----
  if (!reduce) {
    gsap.set([".hero-logo", ".hero-tagline", ".ai", ".trusted", ".site-nav"], { opacity: 0 });
    const tl = gsap.timeline({ defaults: { ease: "power3.out" } });
    tl.to(".site-nav", { opacity: 1, duration: 0.6 })
      .fromTo(".hero-logo", { opacity: 0, scale: 0.95 }, { opacity: 1, scale: 1, duration: 0.9 }, "-=0.2")
      .to(".hero-tagline", { opacity: 1, duration: 0.6 }, "-=0.4")
      .to(".ai", { opacity: 1, duration: 0.6 }, "-=0.3")
      .to(".trusted", { opacity: 1, duration: 0.6 }, "-=0.3");
  }

  // ====================================================================
  //  BACKGROUND SHAPE FIELD — round circles + squares, pulsing open/closed,
  //  cleared in the centre, fading in toward the edges. Fixed to the viewport
  //  so the shapes stay perfectly round (no oval stretching).
  // ====================================================================
  (() => {
    const canvas = document.getElementById("bgDots");
    if (!canvas) return;
    const ctx = canvas.getContext("2d");
    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    const GAP = 38, R = 6;
    let dots = [], w = 0, h = 0, raf = 0;

    function build() {
      w = window.innerWidth; h = window.innerHeight;
      canvas.width = Math.round(w * dpr); canvas.height = Math.round(h * dpr);
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      dots = [];
      const cx = w / 2, cy = h / 2;
      for (let y = GAP / 2; y < h; y += GAP) {
        for (let x = GAP / 2; x < w; x += GAP) {
          // small clear ellipse in the centre (keeps the logo/text clean),
          // shapes fade IN outward — including across the top.
          const dx = (x - cx) / (w * 0.26);
          const dy = (y - cy) / (h * 0.30);
          const vis = Math.min(Math.max((Math.hypot(dx, dy) - 1) / 1.3, 0), 1);
          if (vis <= 0.02) continue;
          const type = (Math.round(x / GAP) + Math.round(y / GAP)) % 3;  // 0 circle, 1 square, 2 diamond
          dots.push({ x, y, edge: vis, type, phase: x * 0.05 + y * 0.045 });
        }
      }
    }
    function shape(type, x, y, s) {
      if (type === 0) { ctx.beginPath(); ctx.arc(x, y, s, 0, Math.PI * 2); ctx.fill(); }
      else if (type === 1) { ctx.fillRect(x - s, y - s, s * 2, s * 2); }
      else { ctx.save(); ctx.translate(x, y); ctx.rotate(Math.PI / 4); ctx.fillRect(-s, -s, s * 2, s * 2); ctx.restore(); }
    }
    function frame(t) {
      ctx.clearRect(0, 0, w, h);
      const time = t * 0.001;
      for (const p of dots) {
        const pulse = 0.5 + 0.5 * Math.sin(time * 0.95 + p.phase);   // opens + closes
        const s = R * (0.22 + 0.78 * pulse);
        const a = p.edge * (0.06 + 0.12 * pulse);
        ctx.fillStyle = `rgba(21,21,15,${a.toFixed(3)})`;
        shape(p.type, p.x, p.y, s);
      }
      raf = requestAnimationFrame(frame);
    }
    function staticDraw() {
      ctx.clearRect(0, 0, w, h);
      for (const p of dots) { ctx.fillStyle = `rgba(21,21,15,${(p.edge * 0.12).toFixed(3)})`; shape(p.type, p.x, p.y, R * 0.6); }
    }
    function start() { build(); if (reduce) staticDraw(); else { cancelAnimationFrame(raf); raf = requestAnimationFrame(frame); } }
    let rt; window.addEventListener("resize", () => { clearTimeout(rt); rt = setTimeout(start, 180); });
    start();
  })();

  // ====================================================================
  //  AI PROMPT (plain text)
  // ====================================================================
  const thread = document.getElementById("aiThread");
  const hint = document.getElementById("aiHint");
  const form = document.getElementById("aiForm");
  const field = document.getElementById("aiField");
  let busy = false;

  function append(el) {
    thread.appendChild(el);
    gsap.fromTo(el, { opacity: 0, y: reduce ? 0 : 8 }, { opacity: 1, y: 0, duration: D(0.4), ease: "power3.out" });
    return el;
  }
  function line(role, html) {
    const el = document.createElement("p");
    el.className = `ai-line ai-${role}`;
    el.innerHTML = html;
    return append(el);
  }
  function thinking() {
    const el = document.createElement("p");
    el.className = "ai-line ai-ai ai-thinking";
    el.innerHTML = `Thinking<span class="dot">.</span><span class="dot">.</span><span class="dot">.</span>`;
    append(el);
    if (!reduce) gsap.to(el.querySelectorAll(".dot"), { opacity: 0.2, duration: 0.5, ease: "power1.inOut", stagger: { each: 0.15, repeat: -1, yoyo: true } });
    return el;
  }

  function showStartupsInline() {
    line("ai", `Love it. Here are the startups you could land at —`);
    const rows = startups.map((s) =>
      `<span class="ai-srow"><span class="ai-sname">${s.name}${s.yc ? ` <span class="ai-yc">${s.yc}</span>` : ""}</span><span class="ai-smeta">${s.meta}</span></span>`).join("");
    line("ai",
      `<span class="ai-slist">${rows}</span>
       <span class="ai-note">You can also browse the <button type="button" class="ai-link" data-open-startups>full startups list</button>, or visit a startup's page (coming soon).</span>
       <button type="button" class="ai-cta" data-continue>Continue to your application →</button>`);
  }

  const FAQ = [
    { q: "When do we hear back?", a: "The first batch goes out late July — early August. Every applicant hears back, accepted or not." },
    { q: "How do I get a higher chance?", a: "Follow us and slide into our DMs — @axiompathways on Instagram, or message the founders directly. Real initiative gets noticed." },
    { q: "Why should I get in?", a: "You get dropped into a real startup building what ships, and you learn straight from founders — not a classroom. Picked for passion, not credentials." },
    { q: "What if I don't get accepted?", a: "You still walk away ahead. We don't leave anyone with nothing — we'll show you exactly what to learn to land an internship, and you can still learn from top entrepreneurs." },
    { q: "What do you do with interns?", a: "Way more than busywork. We teach you what the role actually needs and get you ready to do real startup work — the goal is you becoming someone they want to hire." },
  ];
  function showQuestions() {
    line("ai", `Common questions — tap one, or just ask your own:`);
    line("ai", `<span class="ai-cmds">${FAQ.map((f) => `<button type="button" class="ai-chip" data-cmd="${f.q.replace(/"/g, "&quot;")}">${f.q}</button>`).join("")}</span>`);
  }

  function showMenu() {
    line("ai", `Here's everything you can do — tap one, or just type it:`);
    line("ai",
      `<span class="ai-cmds">
        <button type="button" class="ai-chip" data-cmd="apply">Apply</button>
        <button type="button" class="ai-chip" data-cmd="startups">Startups</button>
        <button type="button" class="ai-chip" data-cmd="questions">Common questions</button>
        <button type="button" class="ai-chip" data-cmd="contact">Contact us</button>
        <button type="button" class="ai-chip" data-cmd="socials">Socials</button>
        <a class="ai-chip" href="https://www.linkedin.com/company/axiom-pathways/" target="_blank" rel="noopener">LinkedIn</a>
      </span>`);
  }
  function showContact() {
    line("ai", `Reach the founders directly:`);
    line("ai",
      `<span class="ai-contact">
        <span class="ai-cgroup">
          <span class="ai-cname">Matthew Park</span>
          <a class="ai-link" href="https://www.linkedin.com/in/matthew-park-487889350/" target="_blank" rel="noopener">LinkedIn ↗</a>
          <a class="ai-link" href="https://www.instagram.com/matty.park/" target="_blank" rel="noopener">Instagram ↗</a>
        </span>
        <span class="ai-cgroup">
          <span class="ai-cname">Frank Niu</span>
          <a class="ai-link" href="https://www.linkedin.com/in/frank-niu-55054a290/" target="_blank" rel="noopener">LinkedIn ↗</a>
        </span>
      </span>`);
  }
  function showSocials() {
    line("ai",
      `Follow Axiom: <a class="ai-link" href="https://www.instagram.com/axiompathways/" target="_blank" rel="noopener">Instagram ↗</a> · <a class="ai-link" href="https://www.linkedin.com/company/axiom-pathways/" target="_blank" rel="noopener">LinkedIn ↗</a> · <a class="ai-link" href="/social">all socials →</a>`);
  }

  function respond(text) {
    const t = text.trim().toLowerCase();
    const faqExact = FAQ.find((f) => f.q.toLowerCase() === t);
    if (faqExact) return { reply: faqExact.a };
    if (t === "?" || t === "help" || t.includes("option")) return { fn: showMenu };
    if (t.includes("question") || t === "faq" || t.includes("faqs")) return { fn: showQuestions };
    if (/\bapply\b/.test(t)) return { fn: showStartupsInline };
    if (t.includes("contact")) return { fn: showContact };
    // FAQ keyword fallbacks (before generic how/who/what + social to avoid collisions)
    if (t.includes("hear back") || (t.includes("when") && t.includes("back"))) return { reply: FAQ[0].a };
    if (t.includes("chance") || t.includes("improve") || t.includes("better odds")) return { reply: FAQ[1].a };
    if (t.includes("why should") || t.includes("why apply") || t.includes("why join") || t.includes("why get in")) return { reply: FAQ[2].a };
    if (t.includes("not accepted") || t.includes("rejected") || t.includes("don't get") || t.includes("dont get") || t.includes("if i don")) return { reply: FAQ[3].a };
    if (t.includes("intern") && (t.includes("do with") || t.includes("what do") || t.includes("happen"))) return { reply: FAQ[4].a };
    if (t.includes("startup")) return { fn: showStartupsInline };
    if (t.includes("social") || t.includes("follow") || t.includes("instagram") || t.includes("linkedin")) return { fn: showSocials };
    if (t.includes("how")) return { reply: `To get an internship at a real startup, or to learn directly from top entrepreneurs. Type <strong>Apply</strong> whenever you're ready.` };
    if (t.includes("who") || t.includes("what")) return { reply: `Axiom Pathways drops students straight into real startups — building what ships, not slide decks. Picked for passion, not credentials. Type <strong>Apply</strong> to start.` };
    return { reply: `Type <strong>?</strong> to see everything you can do, or <strong>Apply</strong> to start your application.` };
  }

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    const text = field.value.trim();
    if (!text || busy) return;
    busy = true; hint.style.display = "none"; field.value = "";
    line("user", text.replace(/</g, "&lt;"));
    const r = respond(text);
    const think = thinking();
    await new Promise((res) => setTimeout(res, reduce ? 250 : 1200));
    think.remove();
    if (r.fn) r.fn(); else line("ai", r.reply);
    busy = false;
  });

  thread.addEventListener("click", (e) => {
    if (e.target.closest("[data-continue]")) startApplication(e.target.closest("[data-continue]"));
    if (e.target.closest("[data-open-startups]")) openStartups();
    const chip = e.target.closest("[data-cmd]");
    if (chip && !busy) { field.value = chip.dataset.cmd; form.requestSubmit(); }
  });

  // ====================================================================
  //  FULL STARTUPS overlay — expandable rows
  // ====================================================================
  const startupsFlow = document.getElementById("startupsFlow");
  function openStartups() {
    startupsFlow.classList.add("open"); startupsFlow.setAttribute("aria-hidden", "false");
    document.body.style.overflow = "hidden"; lenis?.stop();
    if (!reduce) gsap.fromTo(startupsFlow.querySelectorAll(".p-row"), { opacity: 0, y: 18 }, { opacity: 1, y: 0, duration: 0.5, ease: "power3.out", stagger: 0.06, delay: 0.15 });
    gsap.fromTo(startupsFlow, { opacity: 0 }, { opacity: 1, duration: D(0.4) });
  }
  function closeStartups() {
    startupsFlow.classList.remove("open"); startupsFlow.setAttribute("aria-hidden", "true");
    document.body.style.overflow = ""; lenis?.start();
  }
  document.getElementById("startupsX").addEventListener("click", closeStartups);
  startupsFlow.querySelector("[data-close-flow]").addEventListener("click", closeStartups);

  // click a row to expand (hover also expands via CSS)
  startupsFlow.querySelectorAll(".p-row").forEach((row) => {
    row.addEventListener("click", () => {
      const wasOpen = row.classList.contains("open");
      startupsFlow.querySelectorAll(".p-row.open").forEach((r) => r.classList.remove("open"));
      if (!wasOpen) row.classList.add("open");
    });
  });

  // ====================================================================
  //  APPLICATION — inline, one step at a time
  // ====================================================================
  const STEPS = [
    { title: "Let's start with you.", fields: [
      { label: "Full name", name: "name", type: "text", required: true, autocomplete: "name" },
      { label: "Email", name: "email", type: "email", required: true, autocomplete: "email" },
      { label: "Phone", name: "phone", type: "tel", required: true, autocomplete: "tel" },
      { label: "School", name: "school", type: "text", required: true },
      { label: "Grade / Year", name: "grade", type: "select", required: true, options: ["9th grade","10th grade","11th grade","12th grade","College — Freshman","College — Sophomore","College — Junior","College — Senior","Other"] },
    ]},
    { title: "Where do you want to fit?", fields: [
      { label: "Main interest", name: "interest", type: "select", required: true, options: ["AI","Computer Science","Marketing","Finance","Startups","Other"] },
      { label: "City / Chapter", name: "chapter", type: "text", required: true, placeholder: "e.g. Bay Area, Online" },
      { label: "What internship are you looking for?", name: "startup_role", type: "textarea", required: true, placeholder: "e.g. AI engineer at an early-stage startup…" },
      { label: "Why that, and what's your background?", name: "background", type: "textarea", required: true, placeholder: "What draws you to it, what you've done so far…" },
      { label: "What fields are you interested in?", name: "fields_interest", type: "textarea", required: true, placeholder: "e.g. AI infra, consumer growth, fintech…" },
      { label: "Which startups specifically?", name: "startup_picks", type: "textarea", required: true, placeholder: "FinalDose, Stealth, Anvara, Tally, Quarter Life Crisis, Topit AI, TypeOS" },
    ]},
    { title: "A little more.", sub: "Optional — but it helps.", fields: [
      { label: "What do you want to build, and why?", name: "letter", type: "textarea", placeholder: "A few sentences is plenty." },
      { label: "Instagram", name: "instagram", type: "text", placeholder: "@handle" },
      { label: "LinkedIn", name: "linkedin", type: "text", placeholder: "profile URL" },
      { label: "GitHub", name: "github", type: "text", placeholder: "@username" },
      { label: "Other link", name: "other_link", type: "text", placeholder: "portfolio, X, TikTok…" },
      { label: "Resume / CV", name: "resume", type: "file", accept: ".pdf,.doc,.docx,application/pdf", hint: "PDF or DOC · max 8MB" },
      { label: "Additional file", name: "extra_file", type: "file", accept: ".pdf,.doc,.docx,.png,.jpg,.jpeg,.gif,image/*,application/pdf", hint: "Image, PDF, anything · max 8MB" },
      { label: "Anything else you'd like to share?", name: "comments", type: "textarea", placeholder: "A note to the team — anything goes." },
    ]},
  ];

  function fieldHTML(f) {
    const req = f.required ? " required" : "";
    let control;
    if (f.type === "select") {
      const opts = ['<option value="" disabled selected>Select…</option>'].concat(f.options.map((o) => `<option>${o}</option>`)).join("");
      control = `<select name="${f.name}"${req}>${opts}</select>`;
    } else if (f.type === "textarea") {
      control = `<textarea name="${f.name}"${req} placeholder="${f.placeholder || ""}"></textarea>`;
    } else if (f.type === "file") {
      control = `<label class="dropzone" data-drop="${f.name}">
        <input type="file" name="${f.name}" accept="${f.accept || ""}" hidden />
        <span class="dz-icon" aria-hidden="true">↥</span>
        <span class="dz-text">Click to upload or drag and drop</span>
        <span class="dz-hint">${f.hint || ""}</span>
        <span class="dz-file" hidden></span>
      </label>`;
    } else {
      control = `<input type="${f.type}" name="${f.name}"${req} placeholder="${f.placeholder || ""}"${f.autocomplete ? ` autocomplete="${f.autocomplete}"` : ""} />`;
    }
    return `<div class="ifield"><label>${f.label}</label>${control}</div>`;
  }

  let formBlock = null, formStep = 0, formData = {}, formFiles = {};

  function renderForm(i) {
    const s = STEPS[i];
    const dots = STEPS.map((_, k) => `<span class="ap-dot${k <= i ? " is-on" : ""}"></span>`).join("");
    const last = i === STEPS.length - 1;
    formBlock.innerHTML = `
      <div class="aiform-progress">${dots}</div>
      <p class="aiform-label">${i + 1} of ${STEPS.length} · ${s.title}</p>
      ${s.sub ? `<p class="aiform-sub">${s.sub}</p>` : ""}
      <div class="aiform-fields">${s.fields.map(fieldHTML).join("")}</div>
      <div class="aiform-nav">
        ${i > 0 ? `<button type="button" class="aiform-back" data-form-back>← Back</button>` : ""}
        <button type="button" class="aiform-next" data-form-${last ? "submit" : "next"}>${last ? "Submit →" : "Next →"}</button>
      </div>`;
    formBlock.querySelectorAll("input, select, textarea").forEach((f) => { if (f.name && formData[f.name] != null) f.value = formData[f.name]; });
    // restore any already-picked files (file inputs can't be re-populated, so we show the name)
    formBlock.querySelectorAll(".dropzone").forEach((dz) => {
      const file = formFiles[dz.dataset.drop];
      if (file) { dz.classList.add("has-file"); const el = dz.querySelector(".dz-file"); el.textContent = "✓ " + file.name; el.hidden = false; }
    });
    if (!reduce) gsap.fromTo(formBlock.querySelectorAll(".ifield, .aiform-nav"), { opacity: 0, x: 18 }, { opacity: 1, x: 0, duration: 0.35, ease: "power3.out", stagger: 0.04 });
  }
  function collectForm() { formBlock.querySelectorAll("input, select, textarea").forEach((f) => { if (f.name) formData[f.name] = f.value; }); }
  function validateForm() { for (const f of formBlock.querySelectorAll("input, select, textarea")) if (!f.checkValidity()) { f.reportValidity(); return false; } return true; }

  const MAX_FILE = 8 * 1024 * 1024;
  function setFile(name, file, dz) {
    const zone = dz || (formBlock && formBlock.querySelector(`[data-drop="${name}"]`));
    const el = zone && zone.querySelector(".dz-file");
    if (file && file.size > MAX_FILE) {
      if (el) { el.textContent = "That file's over 8MB — pick a smaller one."; el.hidden = false; }
      if (zone) zone.classList.remove("has-file");
      delete formFiles[name]; return;
    }
    if (!file) return;
    formFiles[name] = file;
    if (zone && el) { zone.classList.add("has-file"); el.textContent = "✓ " + file.name; el.hidden = false; }
  }
  function fileToBase64(file) {
    return new Promise((res, rej) => { const r = new FileReader(); r.onload = () => res((r.result + "").split(",")[1] || ""); r.onerror = rej; r.readAsDataURL(file); });
  }
  async function attachFiles() {
    for (const name of Object.keys(formFiles)) {
      const file = formFiles[name];
      if (!file || file.size > MAX_FILE) continue;
      formData[name + "_name"] = file.name;
      formData[name + "_type"] = file.type || "application/octet-stream";
      formData[name + "_base64"] = await fileToBase64(file);
    }
  }
  function finishApplication() {
    formBlock.innerHTML = `
      <div class="aiform-done">
        <svg viewBox="0 0 52 52" width="56" height="56"><circle class="dc-circle" cx="26" cy="26" r="24" fill="none"/><path class="dc-check" fill="none" d="M15 27l7 7 15-16"/></svg>
        <h3 class="done-title">Application sent.</h3>
        <p class="done-sub">We read every one. The first batch goes out late July — early August, and <strong>every applicant hears back</strong>.</p>
      </div>`;
    // follow-up below the box: invite them to follow along
    setTimeout(() => {
      line("ai",
        `In the meantime — want to keep up with who we're placing, what we're building, and the startups we're bringing on? Follow Axiom on <a class="ai-link" href="https://www.linkedin.com/company/axiom-pathways" target="_blank" rel="noopener">LinkedIn</a>, or see <a class="ai-link" href="/social">all our socials →</a>`);
    }, reduce ? 200 : 700);
  }

  // Live submission → Apps Script webhook (Google Sheet). Same field names as the
  // sheet HEADERS; no-cors response is opaque, so fire-and-forget.
  const WEBHOOK_URL = "https://script.google.com/macros/s/AKfycbwxvxSnqkHtXmDmZivo-AW4BllLdT5mWQrQYoV2v1J47hojuEvpf5GPzIGlppkO1K0c/exec";
  function submitToSheet() {
    try { fetch(WEBHOOK_URL, { method: "POST", mode: "no-cors", body: new URLSearchParams(formData) }); }
    catch (_) {}
  }

  async function startApplication(trigger) {
    if (trigger) trigger.remove();
    formData = {}; formStep = 0;
    const think = thinking();
    await new Promise((r) => setTimeout(r, reduce ? 200 : 1000));
    think.remove();
    line("ai", `Perfect — let's do this. One step at a time.`);
    formBlock = document.createElement("div");
    formBlock.className = "ai-form";
    append(formBlock);
    renderForm(formStep);
  }

  thread.addEventListener("click", async (e) => {
    if (e.target.closest("[data-form-next]")) {
      if (!validateForm()) return;
      collectForm(); formStep++; renderForm(formStep);
      formBlock.scrollIntoView({ behavior: reduce ? "auto" : "smooth", block: "center" });
    } else if (e.target.closest("[data-form-back]")) {
      collectForm(); formStep--; renderForm(formStep);
    } else if (e.target.closest("[data-form-submit]")) {
      if (!validateForm()) return;
      collectForm();
      await attachFiles();   // base64-encode resume + extra file into formData
      submitToSheet();       // → live Google Sheet
      finishApplication();
    }
  });

  // ---- File dropzones (resume + extra file): click, change, drag & drop ----
  thread.addEventListener("change", (e) => {
    const inp = e.target.closest('input[type="file"]');
    if (inp) setFile(inp.name, inp.files[0], inp.closest(".dropzone"));
  });
  ["dragenter", "dragover"].forEach((ev) => thread.addEventListener(ev, (e) => {
    const dz = e.target.closest(".dropzone"); if (!dz) return;
    e.preventDefault(); dz.classList.add("is-drag");
  }));
  ["dragleave", "dragend"].forEach((ev) => thread.addEventListener(ev, (e) => {
    const dz = e.target.closest(".dropzone"); if (dz) dz.classList.remove("is-drag");
  }));
  thread.addEventListener("drop", (e) => {
    const dz = e.target.closest(".dropzone"); if (!dz) return;
    e.preventDefault(); dz.classList.remove("is-drag");
    const inp = dz.querySelector('input[type="file"]');
    const f = e.dataTransfer.files && e.dataTransfer.files[0];
    if (f) setFile(inp.name, f, dz);
  });

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && startupsFlow.classList.contains("open")) closeStartups();
  });

  // ---- Page transition: fade out before navigating to an internal page ----
  document.addEventListener("click", (e) => {
    const a = e.target.closest("a[href]");
    if (!a) return;
    const url = a.getAttribute("href");
    if (!url || a.target === "_blank" || /^(https?:|mailto:|#)/.test(url)) return;
    e.preventDefault();
    if (reduce) { window.location.href = url; return; }
    document.body.classList.add("is-leaving");
    setTimeout(() => { window.location.href = url; }, 280);
  });
</script>

