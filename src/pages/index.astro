  .trusted-label { font-family: var(--font-sans); font-size: 0.8rem; letter-spacing: 0.04em; color: var(--muted); margin-bottom: 16px; }
  .trusted-marquee { overflow: hidden; -webkit-mask-image: linear-gradient(90deg, transparent, #000 10%, #000 90%, transparent); mask-image: linear-gradient(90deg, transparent, #000 10%, #000 90%, transparent); }
  .trusted-track { list-style: none; display: flex; align-items: center; gap: clamp(28px, 5vw, 56px); width: max-content; animation: marqueeLeft 40s linear infinite; }
  .trusted-track:hover { animation-play-state: paused; }
  @keyframes marqueeLeft { to { transform: translateX(-50%); } }
  @media (prefers-reduced-motion: reduce) { .trusted-track { animation: none; flex-wrap: wrap; justify-content: center; width: auto; } }
  .trusted-logo { font-family: var(--font-serif); font-size: clamp(1rem, 2vw, 1.25rem); color: var(--muted); opacity: 0.7; white-space: nowrap; transition: opacity .25s, color .25s; }
  .trusted-logo:hover { opacity: 1; color: var(--ink); }
  .trusted-yc { font-family: var(--font-sans); font-size: 0.58rem; font-weight: 600; letter-spacing: 0.06em; color: var(--green); vertical-align: super; }

  /* ---------------- How can I use ---------------- */
  .howuse { max-width: var(--maxw); margin: 0 auto; padding: clamp(80px, 14vh, 160px) clamp(22px, 5vw, 56px); }
  .howuse-title { font-family: var(--font-serif); font-weight: 500; font-size: clamp(2.2rem, 6vw, 4rem); letter-spacing: -0.02em; line-height: 1.02; text-wrap: balance; }
  .howuse-sub { margin-top: 18px; max-width: 46ch; color: var(--muted); font-family: var(--font-serif); font-size: clamp(1.1rem, 2vw, 1.35rem); line-height: 1.55; text-wrap: pretty; }

  /* ---------------- Full startups overlay ---------------- */
  .flow { position: fixed; inset: 0; z-index: 60; background: var(--page); padding: clamp(72px, 12vh, 130px) clamp(24px, 6vw, 88px) clamp(80px, 12vh, 120px); display: flex; flex-direction: column; opacity: 0; visibility: hidden; pointer-events: none; overflow-y: auto; }
  .flow.open { opacity: 1; visibility: visible; pointer-events: auto; }
  .flow-eyebrow { font-family: var(--font-sans); font-size: 0.72rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--muted); }
  .flow-title { font-family: var(--font-serif); font-weight: 500; font-size: clamp(2rem, 5vw, 3.4rem); letter-spacing: -0.015em; line-height: 1.05; margin-top: 12px; text-wrap: balance; }
  .flow-foot { display: flex; align-items: center; justify-content: space-between; gap: 20px; margin-top: clamp(32px, 6vh, 56px); flex-wrap: wrap; }
