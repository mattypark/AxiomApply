<style>
  /* ---------------- Background field ---------------- */
  .bg-dots { position: fixed; inset: 0; z-index: 0; pointer-events: none; }
  /* lift only the in-flow content above the canvas — must NOT touch .flow/.site-nav
     (those manage their own fixed positioning + stacking). */
  .hero, .howuse, .site-footer { position: relative; z-index: 1; }

  /* ---------------- Top nav (links only, no chrome) ---------------- */
  .site-nav { position: fixed; top: 0; left: 0; right: 0; z-index: 40; display: flex; align-items: center; justify-content: center; gap: clamp(18px, 3vw, 38px); padding: 22px clamp(20px, 4vw, 48px); font-family: var(--font-sans); font-size: 0.92rem; background: transparent; }
  .site-nav a, .link-btn { color: var(--muted); transition: color .22s; }
