  .ai-hint strong { color: var(--ink); font-weight: 600; }
  .ai-input { display: flex; align-items: center; gap: 10px; background: var(--card); border: 1px solid var(--line); border-radius: 16px; padding: 8px 10px 8px 12px; box-shadow: 0 8px 30px rgba(21,21,15,0.06); }
  .ai-plus { display: grid; place-items: center; width: 30px; height: 30px; flex-shrink: 0; border: 1px solid var(--line); border-radius: 999px; color: var(--muted); font-size: 1.1rem; }
